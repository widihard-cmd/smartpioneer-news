---
/**
 * NewsCard.astro
 * Kartu artikel berita dengan efek glassmorphism Pi theme.
 * Mendukung Framer Motion melalui data-attribute + CSS custom animation.
 */

interface Props {
  title: string;
  excerpt: string;
  slug: string;
  publishedAt: string;
  category?: string;
  coverImage?: string;
  readTime?: number;
}

const {
  title,
  excerpt,
  slug,
  publishedAt,
  category = 'Pi Network',
  coverImage,
  readTime = 3,
} = Astro.props;

const formattedDate = new Date(publishedAt).toLocaleDateString('id-ID', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<article
  class="news-card glass-card group cursor-pointer overflow-hidden animate-slide-up"
  data-slug={slug}
  onclick={`window.location.href='/news/${slug}'`}
  role="link"
  tabindex="0"
  aria-label={`Baca artikel: ${title}`}
  onkeydown={`if(event.key==='Enter') window.location.href='/news/${slug}'`}
>
  <!-- Cover Image -->
  {coverImage && (
    <div class="h-44 overflow-hidden relative">
      <img
        src={coverImage}
        alt={title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
        decoding="async"
      />
      <!-- Category badge overlay -->
      <div class="absolute top-3 left-3">
        <span class="pi-badge">{category}</span>
      </div>
    </div>
  )}

  <!-- Content -->
  <div class="p-5">
    {!coverImage && (
      <div class="mb-3">
        <span class="pi-badge">{category}</span>
      </div>
    )}

    <h2 class="text-base font-semibold text-white leading-snug mb-2 line-clamp-2 group-hover:text-gold-300 transition-colors duration-200">
      {title}
    </h2>

    <p class="text-sm text-pi-300/60 leading-relaxed line-clamp-3 mb-4">
      {excerpt}
    </p>

    <!-- Meta -->
    <div class="flex items-center justify-between text-xs text-pi-300/40">
      <time datetime={publishedAt}>{formattedDate}</time>
      <span class="flex items-center gap-1">
        <span>⏱</span>
        {readTime} menit baca
      </span>
    </div>
  </div>

  <!-- Bottom gold accent line -->
  <div
    class="h-0.5 w-0 bg-gradient-to-r from-pi-600 to-gold-500 group-hover:w-full transition-all duration-500"
    aria-hidden="true"
  />
</article>

<style>
  .news-card {
    transition: transform 0.25s cubic-bezier(0.16,1,0.3,1), box-shadow 0.25s ease;
  }
  .news-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 48px rgba(0,0,0,0.5), 0 0 30px rgba(245,197,24,0.1);
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
