---
const response = await fetch("https://api.coingecko.com/api/v3/simple/price?ids=pi-network&vs_currencies=idr&include_24hr_change=true");
const data = await response.json();
const price = data["pi-network"].idr;
const change = data["pi-network"].idr_24h_change.toFixed(2);
---

<div class="bg-gray-800 p-4 rounded-lg text-white font-mono">
  <h3 class="text-sm text-gray-400">Harga Pi (IDR)</h3>
  <p class="text-xl font-bold">Rp {price.toLocaleString()}</p>
  <p class={`text-sm ${change >= 0 ? 'text-green-400' : 'text-red-400'}`}>
    {change >= 0 ? '▲' : '▼'} {change}%
  </p>
</div>