---
import PriceWidget from './PriceWidget.astro';
const currentPath = Astro.url.pathname;
---
<header class="bg-gray-800 border-b border-gray-700 sticky top-0 z-50">
  <div class="container mx-auto px-4 py-4 flex items-center justify-between">
    <div class="flex items-center gap-8">
      <a href="/" class="text-2xl font-bold text-purple-400 hover:text-purple-300 transition">
        🚀 SmartPioneer
      </a>
      <nav class="hidden md:flex gap-6">
        <a href="/" class={`hover:text-purple-400 transition ${currentPath === '/' ? 'text-purple-400' : 'text-gray-300'}`}>Beranda</a>
        <a href="/berita" class={`hover:text-purple-400 transition ${currentPath === '/berita' ? 'text-purple-400' : 'text-gray-300'}`}>Berita</a>
        <a href="/rekomendasi" class={`hover:text-purple-400 transition ${currentPath === '/rekomendasi' ? 'text-purple-400' : 'text-gray-300'}`}>Rekomendasi</a>
      </nav>
    </div>
    <div class="flex items-center gap-4">
      <PriceWidget />
      <button id="menu-toggle" class="md:hidden text-gray-300 hover:text-white">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>
  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-gray-800 border-t border-gray-700">
    <nav class="container mx-auto px-4 py-4 flex flex-col gap-4">
      <a href="/" class="text-gray-300 hover:text-purple-400">Beranda</a>
      <a href="/berita" class="text-gray-300 hover:text-purple-400">Berita</a>
      <a href="/rekomendasi" class="text-gray-300 hover:text-purple-400">Rekomendasi</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>