---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AffiliateCard from '../../components/AffiliateCard.astro';
import affiliateData from '../../data/affiliate.json';
---

<Layout title="Rekomendasi Produk">
  <Header />
  <main class="container mx-auto px-4 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold mb-2">Rekomendasi Produk Pilihan</h1>
      <p class="text-gray-400">Dapatkan penawaran terbaik dari Pi Network Ecosystem Partner.</p>
    </div>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {affiliateData.map((item) => (
        <AffiliateCard 
          name={item.name} 
          url={item.url} 
          image={item.image || ''} 
        />
      ))}
    </div>
    
    {affiliateData.length === 0 && (
      <div class="text-center py-12">
        <p class="text-gray-400">Belum ada rekomendasi produk. Cek kembali nanti ya!</p>
      </div>
    )}
  </main>
  <Footer />
</Layout>
